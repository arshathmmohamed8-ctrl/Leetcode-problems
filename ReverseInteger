Assume the environment does not allow you to store 64-bit integers (signed or unsigned).

 

Example 1:

Input: x = 123
Output: 321
Example 2:

Input: x = -123
Output: -321
Example 3:

Input: x = 120
Output: 21





class Solution {
    public int reverse(int x) {
       long rev=0;
       while(x!=0){
        rev=rev*10+(x%10);
        x=x/10;
            if(rev>Integer.MAX_VALUE||rev<Integer.MIN_VALUE){
            return 0;
            }
        }
        return (int)rev;
    }
}
